# ============================================================
# QPay credentials (QPay-ээс өгсөн)
# ============================================================
QPAY_USERNAME=DRIFTHUB
QPAY_PASSWORD=өөрийн_шинэ_password_ийг_энд_бичнэ
QPAY_INVOICE_CODE=DRIFTHUB_INVOICE
QPAY_BASE_URL=https://merchant.qpay.mn

# ============================================================
# Shopify
# SHOPIFY_DOMAIN — Admin API дуудалтад зориулсан БАЙНГЫН .myshopify.com URL
# (custom domain байгаа ч энд .myshopify.com хаягийг тавина)
# STOREFRONT_URL — customer-руу буцах primary домэйн
# ============================================================
SHOPIFY_DOMAIN=drift-ub.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_... # Anх удаа хоосон үлдэнэ. OAuth дууссаны дараа token гарна
SHOPIFY_API_KEY=...            # Dev Dashboard → Settings → Client ID
SHOPIFY_API_SECRET=shpss_...   # Dev Dashboard → Settings → Secret
SHOPIFY_API_VERSION=2024-10
STOREFRONT_URL=https://www.driftub.store

# ============================================================
# Энэхүү backend deploy хийсний дараа авах PUBLIC URL
# (Render дээр deploy хийвэл https://qpay-shopify-xxxx.onrender.com)
# ============================================================
PUBLIC_URL=https://your-app.onrender.com

# ============================================================
# Сервэр порт (Render автоматаар 10000 өгдөг)
# ============================================================
PORT=3000

# ============================================================
# Frontend pay.html-ийг хамгаалах токен (random utgaa bichih)
# Shopify thank-you page дээр заавал тохирно
# ============================================================
SHARED_SECRET=санамсаргүй_урт_утга_үүсгэнэ
